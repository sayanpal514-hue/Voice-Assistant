rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - name: string (required) - User's name
    //   - preferences: map (optional) - User preferences
    //   - createdAt: timestamp (required) - Creation time
    //
    // Collection: users/{userId}/messages
    // Document ID: {messageId}
    // Fields:
    //   - userId: string (required) - User ID
    //   - role: string (required) - 'user' or 'model'
    //   - content: string (required) - Message content
    //   - timestamp: timestamp (required) - Message time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'createdAt']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.createdAt is timestamp;
    }

    function isValidMessage(data, userId) {
      return data.keys().hasAll(['userId', 'role', 'content', 'timestamp']) &&
             data.userId == userId &&
             data.role in ['user', 'model'] &&
             data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      
      match /messages/{messageId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidMessage(request.resource.data, userId);
      }
    }
  }
}
